# HubCRM Environment Variables
# Copy this file to .env and adjust values for your environment

COMPOSE_PROJECT_NAME=hubcrm

# Environment
ENV=dev
LOG_LEVEL=INFO

# Keycloak / OIDC
KEYCLOAK_REALM=hubcrm
KEYCLOAK_CLIENT_ID=hubcrm-ui
KEYCLOAK_PUBLIC_URL=http://localhost:8081
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Optional: if you want to verify "aud" in gateway (leave empty for dev)
OIDC_AUDIENCE=

# Redis Streams
REDIS_URL=redis://redis:6379/0
EVENTS_STREAM=case_events

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=analytics

# Postgres Passwords (dev - change in production!)
KEYCLOAK_DB_PASSWORD=keycloak_pw
CASES_DB_PASSWORD=cases_pw
REGISTRY_DB_PASSWORD=registry_pw
ACCOUNTING_DB_PASSWORD=accounting_pw
DOCUMENTS_DB_PASSWORD=documents_pw
CONTACTS_DB_PASSWORD=contacts_pw
ORDERS_DB_PASSWORD=orders_pw
AI_MEMORY_DB_PASSWORD=ai_memory_pw
